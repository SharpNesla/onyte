{
  "name": "@onyte/primitives",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./dist/source/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "solid-js": "^1.9.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0",
    "@solidjs/testing-library": "^0.8.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json && tsc --project tsconfig.source.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  }
}
